# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/artifacts/try-on-judge/

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
# 範本檔不含任何金鑰，必須進版控（CLAUDE.md 引用它作為環境變數說明）
!.env.local.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# FASHN capture 的可續跑狀態含 Provider job ID，只留在本機；baseline 只提交 sanitized summary。
/fixtures/try-on-baselines/*/capture-state.json

# Supabase Dashboard 匯出的本機查詢草稿不屬於 schema／migration，保留在本機且不進版控。
/supabase/snippets/
