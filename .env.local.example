# ===== Supabase =====
# Supabase Dashboard → Connect / Project Settings → API
# publishable key 可安全放在前端；只用於 Supabase Auth session，不可改填 service_role。
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
# 後端管理 client 使用；可與 NEXT_PUBLIC_SUPABASE_URL 相同。
SUPABASE_URL=https://your-project-ref.supabase.co
# service_role key：只能放在後端環境變數，絕對不可出現在前端程式碼
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# 選用：唯讀 Try-On baseline report 使用。未設定時會降級用 Supabase Data／Storage API，
# 仍可取得 job 與 Storage 指標，但 relation/database 實體容量會標示 unavailable。
# 建議使用權限受限的唯讀 Postgres 帳號；此連線字串同樣不可提交或輸出。
DB_URL=

# ===== V0.7 模擬金流 =====
# 只用於後端驗證 Mock Payment Webhook，並非真實金流憑證；正式／Preview 環境請填至少 32 字元的隨機值。
MOCK_PAYMENT_WEBHOOK_SECRET=replace-with-a-random-secret-at-least-32-characters
# 正式環境預設停用 Mock；只有封閉測試環境才可設 true，公開營運不可開啟。
ENABLE_MOCK_PAYMENTS_IN_PRODUCTION=false

# ===== V1.0 Email / Cron =====
NEXT_PUBLIC_APP_URL=https://your-production-domain.example
# 兩者都不填時為「只記錄通知」測試模式：通知會保存為 skipped，不會寄送或重試。
# 有驗證過的寄件網域後，再同時填入兩者啟用正式寄送。
RESEND_API_KEY=
EMAIL_FROM="樣衣間 <no-reply@your-verified-domain.example>"
# Vercel Cron 與內部維護 API 共用；至少 32 字元高熵隨機值。
CRON_SECRET=replace-with-a-random-secret-at-least-32-characters
# 用於 Email、IP、User-Agent 的不可逆 HMAC 指紋；至少 32 字元，與其他 secret 分離。
RISK_HASH_SECRET=replace-with-another-random-secret-at-least-32-characters

# 帳戶刪除包含 Auth 帳戶刪除與個資去識別化。完成 staging 演練前維持 false。
ACCOUNT_DELETION_EXECUTION_ENABLED=false

# ===== 成本安全 =====
# 平台每日可預留的 AI 成本上限（USD）；到達後所有會員的新生成 fail-closed。
PLATFORM_DAILY_BUDGET_USD=5

# ===== Virtual Try-On Provider =====
# mock      = 假的 provider，不需要 API key，約 3 秒回傳示範結果圖
# fashn     = 真實 FASHN Virtual Try-On API，tryon-v1.6（https://fashn.ai）
# fashn-max = 真實 FASHN Try-On Max，與 fashn 共用同一把 key，品質較高、成本約兩倍，供對比用
VTO_PROVIDER=fashn

# 只有 VTO_PROVIDER=fashn 或 fashn-max 時才需要（兩者共用同一把 key）
FASHN_API_KEY=

# ===== 結果圖放大（Enhance）後處理 =====
# none       = 停用（預設），行為與未加入此功能前完全一致，可作為回滾開關
# realesrgan = Real-ESRGAN 2× 放大（經 Replicate API，約 USD 0.0025/張）。
#              只作用於 v1.6（fashn）的結果，補其固定 864×1296 的解析度缺口；
#              mock / fashn-max 一律跳過。放大失敗會自動降級回原圖，不影響生成結果。
ENHANCE_PROVIDER=none

# 只有 ENHANCE_PROVIDER=realesrgan 時才需要（https://replicate.com/account/api-tokens）
# 只能放在後端環境變數，絕對不可出現在前端程式碼
REPLICATE_API_TOKEN=

# ===== Try-On Feature Flag／實驗矩陣（預設完全停用） =====
# 未設定 TRY_ON_FEATURE_FLAG_CONFIG 時，沿用 VTO_PROVIDER／ENHANCE_PROVIDER，並記為
# deployment-control。設定值必須是單行 JSON；正式啟用前先用下方 example fixture 做離線 observation。
# evaluation 只在明確離線注入時跑 candidate；網站 runtime 仍使用 control。
# canary 才會依 Auth user ID 的後端 HMAC 做穩定分流；禁止使用 NEXT_PUBLIC_ 前綴。
TRY_ON_FEATURE_FLAG_CONFIG=
# evaluation／canary 必填至少 32 字元高熵 secret；不可提交、輸出或與其他 secret 共用。
TRY_ON_FEATURE_FLAG_HMAC_SECRET=

# ===== 離線觸發的 A/B AI Judge CLI =====
# 只在手動執行 `npm run try-on:judge -- --execute` 時使用；不供網站 runtime 使用。
# 未加 --execute 的 dry-run 不需要金鑰，也不會送出圖片。
OPENAI_API_KEY=
# 選用；預設 gpt-5.6。正式比較可改成當時可用的明確 snapshot model。
AI_JUDGE_MODEL=gpt-5.6
